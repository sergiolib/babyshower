# ID de la hoja de cálculo de Google (está en la URL de la hoja)
GOOGLE_SHEETS_SPREADSHEET_ID=tu_spreadsheet_id_aqui

# Ruta absoluta al archivo JSON de credenciales de la Cuenta de Servicio
# Ejemplo: /Users/usuario/descargas/credenciales.json
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/archivo-credenciales.json

# Puerto del servidor (opcional)
PORT=5001
