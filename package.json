{
  "name": "babyshower",
  "version": "1.0.0",
  "description": "BabyShower React & NodeJS Application",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "nodemon server.js",
    "dev:ui": "cd frontend && npm run dev",
    "build:ui": "cd frontend && npm install && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Antigravity",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
